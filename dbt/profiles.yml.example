snowflake_migration:
  target: dev

  outputs:
    # Local dev target: LSILINDA + FR_ENGINEER + ANALYTICS_DEV.
    dev:
      type: snowflake
      account: "{{ env_var('SNOWFLAKE_ACCOUNT') }}"
      user: "{{ env_var('SNOWFLAKE_USER') }}"
      role: FR_ENGINEER
      warehouse: TRANSFORM_WH
      database: ANALYTICS_DEV
      schema: STAGING
      authenticator: snowflake_jwt
      private_key_path: "{{ env_var('SNOWFLAKE_PRIVATE_KEY_PATH') }}"
      threads: 4

    # CI target: CI_SVC + FR_ENGINEER + ANALYTICS_CI (for GitHub Actions).
    # See ADR-0009 and .github/workflows/dbt_ci.yml.
    ci:
      type: snowflake
      account: "{{ env_var('SNOWFLAKE_ACCOUNT') }}"
      user: "{{ env_var('SNOWFLAKE_USER') }}"
      role: "{{ env_var('SNOWFLAKE_ROLE', 'FR_ENGINEER') }}"
      warehouse: "{{ env_var('SNOWFLAKE_WAREHOUSE', 'TRANSFORM_WH') }}"
      database: "{{ env_var('SNOWFLAKE_DATABASE', 'ANALYTICS_CI') }}"
      schema: STAGING
      authenticator: snowflake_jwt
      private_key_path: "{{ env_var('SNOWFLAKE_PRIVATE_KEY_PATH') }}"
      threads: 4
